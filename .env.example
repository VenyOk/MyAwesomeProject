# Backend -> LLM. With ollama, point this at the OpenAI-compatible endpoint.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=local
LLM_MODEL=qwen3.5:9b
LLM_REQUEST_TIMEOUT=180
# For the bundled text/XML Qwen server instead of Ollama, set:
# LLM_PROVIDER=qwen_server

# Embedding model and its output dimension. These defaults preserve the current index.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Approximate maximum number of tokens injected as recalled memory context.
RECALL_CONTEXT_TOKEN_BUDGET=1200

# Local reminder delivery. Leave quiet-hours values blank to deliver immediately.
APP_TIMEZONE=Europe/Moscow
QUIET_HOURS_START=
QUIET_HOURS_END=

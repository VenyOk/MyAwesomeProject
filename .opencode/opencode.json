{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "env": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["npx.cmd", "-y", "mcp-server-fetch-typescript"],
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "e2b": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@smithery/cli@latest", "run", "e2b"],
      "enabled": true,
      "env": {
        "E2B_API_KEY": "{env:E2B_API_KEY}"
      }
    },
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    }
  }
}
